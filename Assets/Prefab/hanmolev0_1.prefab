--- !u!114 &8918636979664070405
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6681814448380271821}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 76add797bdb1d8c4b8276633f6e67167, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.Robotics.UrdfImporter::Unity.Robotics.UrdfImporter.UrdfPlugin
  PluginText: "<ros2_control name=\"GazeboSystem\" type=\"system\">\r\n  <hardware>\r\n   
    <plugin>gazebo_ros2_control/GazeboSystem</plugin>\r\n  </hardware>\r\n  <joint
    name=\"joint_wheel_front_left\">\r\n    <command_interfaces>\r\n      <command_interface
    name=\"velocity\" />\r\n    </command_interfaces>\r\n    <state_interfaces>\r\n     
    <state_interface name=\"position\" />\r\n      <state_interface name=\"velocity\"
    />\r\n    </state_interfaces>\r\n  </joint>\r\n  <joint name=\"joint_wheel_front_right\">\r\n   
    <command_interfaces>\r\n      <command_interface name=\"velocity\" />\r\n   
    </command_interfaces>\r\n    <state_interfaces>\r\n      <state_interface name=\"position\"
    />\r\n      <state_interface name=\"velocity\" />\r\n    </state_interfaces>\r\n 
    </joint>\r\n  <joint name=\"joint_wheel_rear_left\">\r\n    <command_interfaces>\r\n     
    <command_interface name=\"velocity\" />\r\n    </command_interfaces>\r\n    <state_interfaces>\r\n     
    <state_interface name=\"position\" />\r\n      <state_interface name=\"velocity\"
    />\r\n    </state_interfaces>\r\n  </joint>\r\n  <joint name=\"joint_wheel_rear_right\">\r\n   
    <command_interfaces>\r\n      <command_interface name=\"velocity\" />\r\n   
    </command_interfaces>\r\n    <state_interfaces>\r\n      <state_interface name=\"position\"
    />\r\n      <state_interface name=\"velocity\" />\r\n    </state_interfaces>\r\n 
    </joint>\r\n</ros2_control>"
